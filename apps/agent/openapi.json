{
  "openapi": "3.1.0",
  "info": {
    "title": "ImmoSimple Agent",
    "description": "Agent IA pour la gestion locative — chat, rédaction, classification",
    "version": "0.1.0"
  },
  "paths": {
    "/api/chat": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat",
        "operationId": "chat",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/draft": {
      "post": {
        "tags": [
          "draft"
        ],
        "summary": "Draft",
        "operationId": "draft",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DraftRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DraftResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/classify": {
      "post": {
        "tags": [
          "classify"
        ],
        "summary": "Classify",
        "operationId": "classify",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClassifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClassifyResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "workspace_id": {
            "type": "string",
            "title": "Workspace Id",
            "description": "ID de l'espace de travail"
          },
          "tenant_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tenant Id",
            "description": "ID du locataire pour enrichir le contexte"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/Message"
            },
            "type": "array",
            "minItems": 1,
            "title": "Messages",
            "description": "Historique de la conversation"
          },
          "system_context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "System Context",
            "description": "Contexte additionnel à injecter dans le prompt système"
          }
        },
        "type": "object",
        "required": [
          "workspace_id",
          "messages"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "reply": {
            "type": "string",
            "title": "Reply",
            "description": "Réponse générée par l'IA"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "description": "Modèle utilisé"
          },
          "input_tokens": {
            "type": "integer",
            "title": "Input Tokens"
          },
          "output_tokens": {
            "type": "integer",
            "title": "Output Tokens"
          }
        },
        "type": "object",
        "required": [
          "reply",
          "model",
          "input_tokens",
          "output_tokens"
        ],
        "title": "ChatResponse"
      },
      "ClassifyRequest": {
        "properties": {
          "workspace_id": {
            "type": "string",
            "title": "Workspace Id",
            "description": "ID de l'espace de travail"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Message entrant à classifier"
          }
        },
        "type": "object",
        "required": [
          "workspace_id",
          "message"
        ],
        "title": "ClassifyRequest"
      },
      "ClassifyResponse": {
        "properties": {
          "category": {
            "type": "string",
            "title": "Category",
            "description": "Catégorie du message (maintenance, paiement, réclamation, etc.)"
          },
          "confidence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "description": "Score de confiance entre 0 et 1"
          },
          "summary": {
            "type": "string",
            "title": "Summary",
            "description": "Résumé court du message"
          }
        },
        "type": "object",
        "required": [
          "category",
          "confidence",
          "summary"
        ],
        "title": "ClassifyResponse"
      },
      "DraftRequest": {
        "properties": {
          "workspace_id": {
            "type": "string",
            "title": "Workspace Id",
            "description": "ID de l'espace de travail"
          },
          "tenant_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tenant Id",
            "description": "ID du locataire pour enrichir le contexte"
          },
          "subject": {
            "type": "string",
            "title": "Subject",
            "description": "Sujet du message à rédiger"
          },
          "context": {
            "type": "string",
            "title": "Context",
            "description": "Contexte pour la rédaction (infos locataire, situation, etc.)"
          },
          "recipient_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipient Name",
            "description": "Nom du destinataire"
          },
          "tone": {
            "type": "string",
            "enum": [
              "formal",
              "friendly",
              "neutral"
            ],
            "title": "Tone",
            "description": "Ton du message",
            "default": "formal"
          }
        },
        "type": "object",
        "required": [
          "workspace_id",
          "subject",
          "context"
        ],
        "title": "DraftRequest"
      },
      "DraftResponse": {
        "properties": {
          "draft": {
            "type": "string",
            "title": "Draft",
            "description": "Brouillon de message rédigé"
          },
          "subject": {
            "type": "string",
            "title": "Subject",
            "description": "Objet du message"
          }
        },
        "type": "object",
        "required": [
          "draft",
          "subject"
        ],
        "title": "DraftResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse"
      },
      "Message": {
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ],
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "Message"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}