# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage

# next.js
**/.next/
**/out/

# production
**/build
**/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
**/next-env.d.ts

# python
**/__pycache__
**/*.py[cod]
**/.venv
**/*.egg-info
apps/agent/.venv

# turbo
.turbo
